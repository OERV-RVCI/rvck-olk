config UB_UDMA
	default n
	tristate "UB UDMA Driver"
	depends on UB_UBASE && UB_URMA && UB_UMMU_CORE
	help
	  UDMA driver support for Hisilicon UBUS engine
	  in Hisilicon SoC. To compile this driver,
	  choose Y here: if UB_UDMA is m, this module
	  will be called udma.
