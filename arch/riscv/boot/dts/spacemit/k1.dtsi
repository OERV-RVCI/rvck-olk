				 <&syscon_apbc CLK_AIB_BUS>,
				 <&syscon_apmu CLK_AIB>;
			clock-names = "core", "io", "aib-bus", "aib";
			resets = <&syscon_apmu RESET_SDH_AXI>,
				 <&syscon_apmu RESET_SDH0>;
			reset-names = "core", "io";
			interconnects = <&dram_range0>;
			interconnect-names = "dma-mem";
			status = "disabled";
		};

		sdhci1: sdh@d4280800 {
			compatible = "spacemit,k1-sdhci";
			reg = <0x0 0xd4280800 0x0 0x200>;
			interrupts = <100>;
			interrupt-parent = <&intc>;
			clocks = <&syscon_apmu CLK_SDH_AXI>,
				 <&syscon_apmu CLK_SDH1>;
			clock-names = "core", "io";
			resets = <&syscon_apmu RESET_SDH_AXI>,
				 <&syscon_apmu RESET_SDH1>;
			reset-names = "core", "io";
			interconnects = <&dram_range0>;
			interconnect-names = "dma-mem";
			status = "disabled";
		};

		sdhci2: sdh@d4281000 {
			compatible = "spacemit,k1-sdhci";
			reg = <0x0 0xd4281000 0x0 0x200>;
			interrupts = <101>;
			interrupt-parent = <&intc>;
			clocks = <&syscon_apmu CLK_SDH_AXI>,
				 <&syscon_apmu CLK_SDH2>;
			clock-names = "core", "io";
			resets = <&syscon_apmu RESET_SDH_AXI>,
				 <&syscon_apmu RESET_SDH2>;
			reset-names = "core", "io";
			interconnects = <&dram_range0>;
			interconnect-names = "dma-mem";
			status = "disabled";
		};

		eth0: ethernet@cac80000 {
			compatible = "spacemit,k1-emac";
			reg = <0x0 0xCAC80000 0x0 0x420>;
			k1,apmu-base-reg = <0xD4282800>;
			ctrl-reg = <0x3e4>;
			dline-reg = <0x3e8>;
			clocks = <&syscon_apmu CLK_EMAC0_BUS>,
				 <&syscon_apmu CLK_EMAC0_PTP>;
			clock-names = "emac-clk", "ptp-clk";
			resets = <&syscon_apmu RESET_EMAC0>;
			reset-names = "emac-reset";
			interrupts-extended = <&intc 131>;
			mac-address = [ 00 00 00 00 00 00 ];
			ptp-support;
			ptp-clk-rate = <10000000>;
			interconnects = <&dram_range1>;
			interconnect-names = "dma-mem";
			status = "disabled";
		};

		eth1: ethernet@cac81000 {
			compatible = "spacemit,k1-emac";
			reg = <0x0 0xCAC81000 0x0 0x420>;
			k1,apmu-base-reg = <0xD4282800>;
			ctrl-reg = <0x3ec>;
			dline-reg = <0x3f0>;
			clocks = <&syscon_apmu CLK_EMAC1_BUS>,
				 <&syscon_apmu CLK_EMAC1_PTP>;
			clock-names = "emac-clk", "ptp-clk";
			resets = <&syscon_apmu RESET_EMAC1>;
			reset-names = "emac-reset";
			interrupts-extended = <&intc 133>;
			mac-address = [ 00 00 00 00 00 00 ];
			ptp-support;
			ptp-clk-rate = <10000000>;
			interconnects = <&dram_range1>;
			interconnect-names = "dma-mem";
			status = "disabled";
		};
	};
};
